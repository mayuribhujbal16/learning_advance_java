    <welcome-file>default.jsp</welcome-file>
    <welcome-file>default.htm</welcome-file>
  </welcome-file-list>
  
  <servlet>  

<servlet-name>ServletConfigClass</servlet-name>
<servlet-class>com.ServletConfigClass</servlet-class> 

<init-param>
<param-name>Name</param-name> 
<param-value>Mayuri</param-value>
</init-param>

<init-param>
<param-name>Surname</param-name> 
